    WHEN pcaa.segment1 IS NOT NULL AND pcaa.segment2 IS NOT NULL
    THEN pcaa.segment1 || '.' || pcaa.segment2
    ELSE NULL
  END AS paramconcat1,
  '' AS paramconcat2,
  '' AS paramconcat3,
  '' AS paramconcat4,
  '' AS paramconcat5,
  '' AS paramconcat6,
  '' AS paramconcat7,
  '' AS paramconcat8
FROM per_all_people_f papf
INNER JOIN per_person_names_f ppnf
  ON papf.person_id = ppnf.person_id
INNER JOIN per_email_addresses pea
  ON papf.person_id = pea.person_id
INNER JOIN (
  SELECT person_id,
    MAX(period_of_service_id) AS period_of_service_id
  FROM per_periods_of_service
  GROUP BY person_id
) p_hire_join
  ON p_hire_join.person_id = papf.person_id
INNER JOIN per_periods_of_service ppos
  ON (
    p_hire_join.person_id = ppos.person_id
    AND p_hire_join.period_of_service_id = ppos.period_of_service_id
  )
/* inner join (select person_id, max(period_of_service_id)as period_of_service_id from per_periods_of_service group by person_id)p_ter_join on p_ter_join.person_id = papf.person_id */ /* inner join per_periods_of_service ppfs on (p_ter_join.person_id = ppfs.person_id and p_ter_join.period_of_service_id = ppfs.period_of_service_id) */
INNER JOIN per_persons pp
  ON papf.person_id = pp.person_id
INNER JOIN (
  SELECT person_id,
    MAX(effective_start_date) AS effective_start_date
  FROM per_all_assignments_m
  WHERE TRUNC(SYSDATE) BETWEEN effective_start_date AND effective_end_date
    AND assignment_type IN ('E', 'C')
    AND assignment_status_type = 'INACTIVE'
  GROUP BY person_id
  ORDER BY person_id
) ia
  ON papf.person_id = ia.person_id
INNER JOIN per_all_assignments_m paam
  ON (
    ia.person_id = paam.person_id
    AND ia.effective_start_date = paam.effective_start_date
  )
INNER JOIN hr_organization_units_f_tl houft
  ON houft.organization_id = paam.business_unit_id
INNER JOIN hr_organization_info_eff_v hroie
  ON hroie.organization_id = paam.organization_id
INNER JOIN per_jobs_f pjf
  ON pjf.job_id = paam.job_id
INNER JOIN hr_all_positions_f hapf
  ON hapf.position_id = paam.position_id
INNER JOIN emp_phones_pivot ppp
  ON papf.person_id = ppp.person_id
INNER JOIN emp_emails_pivot eep
  ON papf.person_id = eep.person_id
INNER JOIN per_job_family_f_tl pjfft
  ON pjfft.job_family_id = pjf.job_family_id
INNER JOIN per_person_types_tl pptl
  ON pptl.person_type_id = paam.person_type_id
LEFT OUTER JOIN pay_cost_allocations_f pcaf
  ON (
    pcaf.source_id = paam.organization_id
    AND TRUNC(SYSDATE) BETWEEN pcaf.effective_start_date AND pcaf.effective_end_date
    AND pcaf.source_type = 'ORG'
  )
LEFT OUTER JOIN pay_cost_alloc_accounts pcaa
  ON pcaa.cost_allocation_record_id = pcaf.cost_allocation_record_id
LEFT OUTER JOIN per_job_leg_f pjlf
  ON (
    pjlf.job_id = pjf.job_id
    AND TRUNC(SYSDATE) BETWEEN pjlf.effective_start_date AND pjlf.effective_end_date
    AND pjlf.legislation_code = 'US'
    AND pjlf.information_category = 'HRX_US_JOBS'
  )
LEFT OUTER JOIN per_ext_app_identifiers peai
	ON (
		peai.person_id = paam.person_id 
		AND peai.ext_identifier_type  = 'ORA_TCLOCK_BADGE_ID' 
		AND TO_DATE(:p_effective_date, 'YYYY-MM-DD') BETWEEN peai.date_from AND peai.date_to
	)
LEFT OUTER JOIN accrual_details_pivot aadp
  ON papf.person_id = aadp.person_id
LEFT OUTER JOIN emp_addresses ea
  ON papf.person_id = ea.person_id
LEFT OUTER JOIN element_entries ee
  ON papf.person_id = ee.person_id
LEFT OUTER JOIN per_seniority_dates_f psdf
  ON paam.person_id = psdf.person_id AND psdf.seniority_date_code = 'LC_PER_LEUSD'
LEFT OUTER JOIN hr_lookups hlm
  ON (
    pjf.manager_level = hlm.lookup_code AND hlm.lookup_type = 'MANAGER_LEVEL'
  )
WHERE TRUNC(SYSDATE) BETWEEN papf.effective_start_date AND papf.effective_end_date
  AND TRUNC(SYSDATE) BETWEEN ppnf.effective_start_date AND ppnf.effective_end_date
  AND TRUNC(SYSDATE) BETWEEN paam.effective_start_date AND paam.effective_end_date
  AND TRUNC(SYSDATE) BETWEEN houft.effective_start_date AND houft.effective_end_date
  AND TRUNC(SYSDATE) BETWEEN pjf.effective_start_date AND pjf.effective_end_date
  AND TRUNC(SYSDATE) BETWEEN hapf.effective_start_date AND hapf.effective_end_date
  AND ppnf.name_type = 'GLOBAL'
  AND pea.email_type = 'W1'
  AND paam.assignment_type IN ('E', 'C')
  AND paam.assignment_status_type = 'INACTIVE'
  AND houft.language = USERENV('LANG')
  AND UPPER(houft.name) = UPPER(:p_business_unit)
