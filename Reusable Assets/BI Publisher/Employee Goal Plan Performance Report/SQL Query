WITH SUPERVISOR AS
(
SELECT 
	 C.PERSON_ID
	,B.ASSIGNMENT_ID
	,MAX(C.EFFECTIVE_START_DATE) AS EFFECTIVE_START_DATE
	,MAX(C.EFFECTIVE_END_DATE) AS EFFECTIVE_END_DATE
FROM 
	HRG_GOAL_PLN_ASSIGNMENTS A, 
	HRG_GOAL_PLANS_TL D,
	PER_ALL_ASSIGNMENTS_M B, 
	PER_ASSIGNMENT_SUPERVISORS_F C	
WHERE
	A.GOAL_PLAN_ID=D.GOAL_PLAN_ID
	AND A.PERSON_ID = B.PERSON_ID
	AND TRUNC(SYSDATE) BETWEEN B.EFFECTIVE_START_DATE AND B.EFFECTIVE_END_DATE
	AND B.ASSIGNMENT_TYPE IN ('E','C')
	AND B.PRIMARY_FLAG = 'Y' 
	AND B.ASSIGNMENT_STATUS_TYPE IN ('ACTIVE','SUSPENDED')
	AND C.PERSON_ID = B.PERSON_ID 
	AND B.ASSIGNMENT_ID=C.ASSIGNMENT_ID 
	AND TRUNC(C.EFFECTIVE_START_DATE) <= TRUNC(SYSDATE)
	AND TRUNC(C.EFFECTIVE_START_DATE) <= TRUNC(C.EFFECTIVE_END_DATE)
  AND C.MANAGER_TYPE='LINE_MANAGER'
	AND D.LANGUAGE = 'US'
	AND D.GOAL_PLAN_NAME IN (:Goal_Plan)
GROUP BY 
	C.PERSON_ID, B.ASSIGNMENT_ID
),
WEIGHT AS
(
select
	 GL.PERSON_ID as PERSON_ID
	,GL.GOAL_PLAN_ID as GOAL_PLAN_ID
	,sum(HGPG_AGG.WEIGHTING) AS WEIGHTAGE
from 
	HRG_GOAL_PLN_ASSIGNMENTS GL, 
	HRG_GOAL_PLAN_GOALS HGPG_AGG, 
	HRG_GOALS HGPB_AGG,
  HRG_GOAL_PLANS_TL D	
where 
	GL.GOAL_PLAN_ID=HGPG_AGG.GOAL_PLAN_ID
	AND GL.GOAL_PLAN_ID=D.GOAL_PLAN_ID
	AND HGPB_AGG.GOAL_ID=HGPG_AGG.GOAL_ID 
	AND HGPB_AGG.PERSON_ID= GL.PERSON_ID
  AND HGPB_AGG.ASSIGNMENT_ID= GL.ASSIGNMENT_ID	
	AND HGPB_AGG.GOAL_VERSION_TYPE_CODE <>'MASS_REQ'
	AND HGPG_AGG.GOAL_ID NOT in (SELECT GOAL_ID FROM HRG_GOALS WHERE HGPB_AGG.GOAL_ID=GOAL_ID AND HGPB_AGG.PERSON_ID= PERSON_ID AND HGPB_AGG.ASSIGNMENT_ID= ASSIGNMENT_ID AND GOAL_VERSION_TYPE_CODE = 'FROZEN' AND REQUEST_CONTEXT IS NULL)
	AND D.LANGUAGE = 'US'
	AND D.GOAL_PLAN_NAME IN (:Goal_Plan)
GROUP BY 
	GL.PERSON_ID,GL.GOAL_PLAN_ID
),
GOAL_DETAILS AS
(select 
	 distinct 
	 PAPF.PERSON_ID AS Person_ID
	,PAAM.ASSIGNMENT_ID AS Assignment_ID
	,PAAM.EFFECTIVE_START_DATE AS Effective_Start_Date
	,PAAM.EFFECTIVE_END_DATE AS Effective_End_Date
	,HGP.GOAL_PLAN_NAME AS Goal_Plan_Name
	,HRPT.REVIEW_PERIOD_NAME as Review_Period
	,PAPF.PERSON_NUMBER AS Employee_Id
	,PAAM.ASSIGNMENT_STATUS_TYPE AS Employee_Status
	,PPNF.DISPLAY_NAME AS Employee_Name
	,TO_CHAR(PPOS.DATE_START,'DD-MON-YYYY','NLS_DATE_LANGUAGE = AMERICAN') AS Date_Of_Joining
	,PD.NAME AS DEPT
	,PLDFT.LOCATION_NAME AS Location
	,PGFT.NAME AS Grade
	,PJFTL.NAME AS TSR
	,TO_CHAR(PPFS.ACTUAL_TERMINATION_DATE,'DD-MON-YYYY','NLS_DATE_LANGUAGE = AMERICAN') as TERMINATION_DATE
	,CASE WHEN FWH.ASSIGNEES IS NOT NULL THEN PER_NAME_MGR1.DISPLAY_NAME ELSE PER_NAME_MGR.DISPLAY_NAME END AS Manager_Name
	,CASE WHEN FWH.ASSIGNEES IS NOT NULL THEN PEO_MGR1.PERSON_NUMBER ELSE PEO_MGR.PERSON_NUMBER END AS Manager_Emp_ID
	,WS.WEIGHTAGE as Goal_Plan_Totalage
	,CASE WHEN UPPER(TXN_DATA.STATUS)<>'DRAFT' THEN 'YES' ELSE 'NO' END as Goal_Plan_Submitted_by_Employee
	,case when TXN_DATA.STATUS='COMMIT' THEN 'APPROVED' when TXN_DATA.STATUS='COMPLETE' THEN 'APPROVED' when TXN_DATA.STATUS='ABORTED' THEN 'REJECTED' when TXN_DATA.STATUS='CANCELLED' THEN 'REJECTED' when TXN_DATA.STATUS is NULL AND (WS.WEIGHTAGE IS NOT null and WS.WEIGHTAGE = 100) THEN 'APPROVED' when TXN_DATA.STATUS is NULL THEN 'NOT STARTED' when TXN_DATA.STATUS='PENDING' THEN 'APPROVAL PENDING' when TXN_DATA.STATUS='DRAFT' THEN 'Waiting To Submit For Approval' else TXN_DATA.STATUS end as Employee_Goal_Setting
	,lookup.meaning as Goal_Category
	,HGPB.GOAL_NAME as Goal_Name
	,HGM.Measurement_Name as Metrics
	,HGPG.WEIGHTING as Weightage
	,case when HGPB.GOAL_SOURCE_CODE ='WORKER' THEN 'Individual' when HGPB.GOAL_SOURCE_CODE ='MANAGER' THEN 'Individual' when HGPB.GOAL_SOURCE_CODE='HR' THEN 'Organization' end as Goal_Type
	,TO_CHAR(HGPB.START_DATE,'DD/MON/YYYY') Start_Date
	,TO_CHAR(HGPB.TARGET_COMPLETION_DATE,'DD/MON/YYYY') End_Date
	,case when Status_Code is NULL THEN 'NULL' else HGPB.Status_Code end as Goal_Status
FROM
	PER_ALL_PEOPLE_F PAPF
	INNER JOIN HRG_GOAL_PLN_ASSIGNMENTS GOAL ON PAPF.PERSON_ID=GOAL.PERSON_ID
	INNER JOIN PER_PERSON_NAMES_F PPNF ON PAPF.PERSON_ID = PPNF.PERSON_ID
	INNER JOIN PER_ALL_ASSIGNMENTS_M PAAM ON GOAL.PERSON_ID = PAAM.PERSON_ID 
	INNER JOIN (SELECT PERSON_ID, ASSIGNMENT_ID,MAX(LAST_UPDATE_DATE) AS LAST_UPDATE_DATE FROM PER_ALL_ASSIGNMENTS_M WHERE TRUNC(SYSDATE) BETWEEN EFFECTIVE_START_DATE AND EFFECTIVE_END_DATE AND ASSIGNMENT_TYPE IN ('E','C')AND PRIMARY_FLAG = 'Y' AND ASSIGNMENT_STATUS_TYPE IN('ACTIVE','SUSPENDED')GROUP BY PERSON_ID,ASSIGNMENT_ID) UPD ON (UPD.LAST_UPDATE_DATE = PAAM.LAST_UPDATE_DATE AND UPD.PERSON_ID = PAAM.PERSON_ID AND UPD.ASSIGNMENT_ID = PAAM.ASSIGNMENT_ID)
	INNER JOIN PER_PERIODS_OF_SERVICE PPFS ON (PAAM.PERSON_ID = PPFS.PERSON_ID AND PPFS.PERIOD_TYPE = PAAM.ASSIGNMENT_TYPE)
	INNER JOIN PER_PERIODS_OF_SERVICE PPOS ON PAPF.PERSON_ID = PPOS.PERSON_ID
	INNER JOIN (SELECT PERSON_ID, MIN(PERIOD_OF_SERVICE_ID)AS PERIOD_OF_SERVICE_ID FROM PER_PERIODS_OF_SERVICE GROUP BY PERSON_ID)P_JOIN ON (P_JOIN.PERSON_ID = PPOS.PERSON_ID AND P_JOIN.PERIOD_OF_SERVICE_ID = PPOS.PERIOD_OF_SERVICE_ID)
	INNER JOIN PER_DEPARTMENTS PD ON PAAM.ORGANIZATION_ID=PD.ORGANIZATION_ID 
	INNER JOIN PER_LOCATION_DETAILS_F PLDF ON PAAM.LOCATION_ID=PLDF.LOCATION_ID
	INNER JOIN PER_LOCATION_DETAILS_F_TL PLDFT ON PLDF.LOCATION_DETAILS_ID=PLDFT.LOCATION_DETAILS_ID
	INNER JOIN PER_GRADES_F_TL PGFT ON PAAM.GRADE_ID = PGFT.GRADE_ID
	INNER JOIN PER_JOBS_F_TL PJFTL ON PAAM.JOB_ID = PJFTL.JOB_ID
	INNER JOIN (SELECT PERSON_ID,PERIOD_TYPE,MAX(DATE_START)AS DATE_START FROM PER_PERIODS_OF_SERVICE GROUP BY PERSON_ID,PERIOD_TYPE) P_SERVCE ON (P_SERVCE.PERSON_ID = PPFS.PERSON_ID AND PPFS.PERIOD_TYPE = P_SERVCE.PERIOD_TYPE AND P_SERVCE.DATE_START = PPFS.DATE_START)
	INNER JOIN HRG_GOAL_PLANS_TL HGP ON HGP.GOAL_PLAN_ID=GOAL.GOAL_PLAN_ID
	LEFT OUTER JOIN HRG_GOAL_PLANS_B G_PLN_B ON HGP.GOAL_PLAN_ID=G_PLN_B.GOAL_PLAN_ID
	LEFT OUTER JOIN HRT_REVIEW_PERIODS_TL HRPT ON G_PLN_B.REVIEW_PERIOD_ID=HRPT.REVIEW_PERIOD_ID
	LEFT OUTER JOIN WEIGHT WS ON (GOAL.PERSON_ID = WS.PERSON_ID AND GOAL.GOAL_PLAN_ID = WS.GOAL_PLAN_ID)
	LEFT OUTER JOIN SUPERVISOR SUP ON (SUP.PERSON_ID = PAAM.PERSON_ID AND SUP.ASSIGNMENT_ID = PAAM.ASSIGNMENT_ID) 
	LEFT OUTER JOIN PER_ASSIGNMENT_SUPERVISORS_F PASF ON (PASF.PERSON_ID = SUP.PERSON_ID AND SUP.ASSIGNMENT_ID = PASF.ASSIGNMENT_ID AND SUP.EFFECTIVE_START_DATE = PASF.EFFECTIVE_START_DATE AND SUP.EFFECTIVE_END_DATE = PASF.EFFECTIVE_END_DATE AND PASF.MANAGER_TYPE='LINE_MANAGER')
	LEFT OUTER JOIN PER_PERSON_NAMES_F PER_NAME_MGR ON (PASF.MANAGER_ID=PER_NAME_MGR.PERSON_ID AND TRUNC(SYSDATE) BETWEEN PER_NAME_MGR.EFFECTIVE_START_DATE AND PER_NAME_MGR.EFFECTIVE_END_DATE AND PER_NAME_MGR.NAME_TYPE='GLOBAL')
	LEFT OUTER JOIN PER_ALL_PEOPLE_F PEO_MGR ON (PASF.MANAGER_ID= PEO_MGR.PERSON_ID AND TRUNC(SYSDATE) BETWEEN PEO_MGR.EFFECTIVE_START_DATE AND PEO_MGR.EFFECTIVE_END_DATE)
	LEFT OUTER JOIN(SELECT OBJECT_ID, MAX(LAST_UPDATE_DATE) AS LAST_UPDATE_DATE FROM HRC_TXN_HEADER GROUP BY OBJECT_ID)TXN_HD ON TXN_HD.OBJECT_ID=GOAL.GOAL_PLAN_ASSIGNMENT_ID
	LEFT OUTER JOIN HRC_TXN_HEADER TXN_H ON (TXN_HD.OBJECT_ID = TXN_H.OBJECT_ID  AND TXN_H.LAST_UPDATE_DATE = TXN_HD.LAST_UPDATE_DATE)
	LEFT OUTER JOIN(SELECT TRANSACTION_ID, MAX(LAST_UPDATE_DATE) AS LAST_UPDATE_DATE FROM HRC_TXN_DATA GROUP BY TRANSACTION_ID)TXN_LAST ON TXN_LAST.TRANSACTION_ID=TXN_H.TRANSACTION_ID 
	LEFT OUTER JOIN HRC_TXN_DATA TXN_DATA ON (TXN_LAST.TRANSACTION_ID = TXN_DATA.TRANSACTION_ID AND TXN_DATA.LAST_UPDATE_DATE = TXN_LAST.LAST_UPDATE_DATE)
	LEFT OUTER JOIN HRG_GOAL_PLAN_GOALS HGPG ON (HGPG.GOAL_PLAN_ID=GOAL.GOAL_PLAN_ID AND PAAM.ASSIGNMENT_ID=HGPG.ASSIGNMENT_ID)
	LEFT OUTER JOIN HRG_GOALS HGPB ON HGPB.GOAL_ID=HGPG.GOAL_ID
	LEFT OUTER JOIN HCM_LOOKUPS lookup on (UPPER(HGPB.CATEGORY_CODE)=UPPER(lookup.LOOKUP_CODE) AND lookup.lookup_TYPE ='HRG_PERF_GOAL_CATEGORY')
	LEFT OUTER JOIN HRG_GOAL_MEASUREMENTS  HGM on HGPB.GOAL_ID=HGM.GOAL_ID
	LEFT OUTER JOIN(SELECT IDENTIFICATIONKEY, MAX(UPDATEDDATE) AS LAST_UPDATE_DATE FROM FA_FUSION_SOAINFRA.WFTASK WHERE UPPER(TASKDEFINITIONNAME) = 'APPROVEPERFORMANCEGOAL' GROUP BY IDENTIFICATIONKEY)FUS_LAST ON FUS_LAST.IDENTIFICATIONKEY=TO_CHAR(TXN_H.TRANSACTION_ID) 
	LEFT OUTER JOIN FA_FUSION_SOAINFRA.WFTASK FUS ON (FUS_LAST.IDENTIFICATIONKEY = FUS.IDENTIFICATIONKEY AND FUS_LAST.LAST_UPDATE_DATE = FUS.UPDATEDDATE)
	LEFT OUTER JOIN(SELECT TASKID, MAX(UPDATEDDATE) AS LAST_UPDATE_DATE FROM FA_FUSION_SOAINFRA.WFTASKHISTORY WHERE UPPER(TASKDEFINITIONNAME) = 'APPROVEPERFORMANCEGOAL' AND STATE = 'ASSIGNED' GROUP BY TASKID)FWHL ON FWHL.TASKID = FUS.TASKID
	LEFT OUTER JOIN FA_FUSION_SOAINFRA.WFTASKHISTORY FWH ON (FWHL.TASKID=FWH.TASKID	AND FWHL.LAST_UPDATE_DATE = FWH.UPDATEDDATE)	
	LEFT OUTER JOIN PER_USERS PU ON UPPER(PU.USERNAME)=LTRIM(UPPER(SUBSTR(FWH.ASSIGNEES,1,INSTR(FWH.ASSIGNEES,',')-1)))
	LEFT OUTER JOIN PER_ALL_PEOPLE_F PEO_MGR1 ON (PU.PERSON_ID= PEO_MGR1.PERSON_ID AND TRUNC(SYSDATE) BETWEEN PEO_MGR1.EFFECTIVE_START_DATE AND PEO_MGR1.EFFECTIVE_END_DATE)
	LEFT OUTER JOIN PER_PERSON_NAMES_F PER_NAME_MGR1 ON (PU.PERSON_ID=PER_NAME_MGR1.PERSON_ID AND TRUNC(SYSDATE) BETWEEN PER_NAME_MGR1.EFFECTIVE_START_DATE AND PER_NAME_MGR1.EFFECTIVE_END_DATE AND PER_NAME_MGR1.NAME_TYPE='GLOBAL')
WHERE
	TRUNC(SYSDATE) BETWEEN PAPF.EFFECTIVE_START_DATE AND PAPF.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PPNF.EFFECTIVE_START_DATE AND PPNF.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PAAM.EFFECTIVE_START_DATE AND PAAM.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PD.EFFECTIVE_START_DATE AND PD.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PLDF.EFFECTIVE_START_DATE AND PLDF.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PLDFT.EFFECTIVE_START_DATE AND PLDFT.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PGFT.EFFECTIVE_START_DATE AND PGFT.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PJFTL.EFFECTIVE_START_DATE AND PJFTL.EFFECTIVE_END_DATE
	AND PPNF.NAME_TYPE = 'GLOBAL'
	AND PAAM.ASSIGNMENT_TYPE IN ('E','C')
	AND PAAM.PRIMARY_FLAG = 'Y'
	AND PAAM.ASSIGNMENT_STATUS_TYPE IN('ACTIVE','SUSPENDED')
	AND PLDFT.LANGUAGE = 'US'
	AND PGFT.LANGUAGE = 'US'
	AND HRPT.LANGUAGE = 'US'
	AND (LTRIM(UPPER(HGP.GOAL_PLAN_NAME)) NOT IN (SELECT
	FUR.ROW_NAME 
	FROM
	FUSION.FF_USER_TABLES_VL FUT
	,FUSION.FF_USER_ROWS_VL FUR
	WHERE 1=1
	AND FUT.BASE_USER_TABLE_NAME = 'HEX_PMS_EXCLUDE_GOAL_PLAN_NAME'
	AND FUT.USER_TABLE_ID = FUR.USER_TABLE_ID))
)  
SELECT 
GD.Goal_Plan_Name
,GD.Review_Period
,GD.Employee_Id
,GD.Employee_Status
,GD.Employee_Name
,GD.Date_of_Joining
,GD.DEPT
,GD.Location
,GD.Grade
,GD.TSR
,GD.TERMINATION_DATE
,GD.Manager_Name
,GD.Manager_Emp_ID
,GD.Goal_Plan_Totalage AS "Goal_Plan_Total%age"
,GD.Goal_Plan_Submitted_by_Employee
,GD.Employee_Goal_Setting
,GD.Goal_Category
,GD.Goal_Name
,GD.Metrics
,GD.Weightage
,GD.Goal_Type
,GD.Start_Date
,GD.End_Date
,GD.Goal_Status

FROM
   GOAL_DETAILS GD
	,PER_PERSON_SECURED_LIST_V PAPF
	,PER_ASSIGNMENT_SECURED_LIST_V PAAM 
WHERE
	GD.Person_ID = PAPF.PERSON_ID
	AND GD.Person_ID = PAAM.PERSON_ID 
	AND GD.Assignment_ID = PAAM.ASSIGNMENT_ID
	AND TRUNC(SYSDATE) BETWEEN PAPF.EFFECTIVE_START_DATE AND PAPF.EFFECTIVE_END_DATE
	AND TRUNC(SYSDATE) BETWEEN PAAM.EFFECTIVE_START_DATE AND PAAM.EFFECTIVE_END_DATE
	AND PAAM.ASSIGNMENT_TYPE IN ('E','C')
	AND PAAM.PRIMARY_FLAG = 'Y'
    AND PAAM.ASSIGNMENT_STATUS_TYPE IN('ACTIVE','SUSPENDED')
  AND GD.DEPT IN (:Dept)
  AND GD.Employee_Status IN(:Employee_Status)
  AND GD.Goal_Plan_Name IN (:Goal_Plan)
  AND GD.Grade IN (:Grade)
  AND GD.Location IN( :Location)
  AND GD.Review_Period IN(:Review_Period)
  AND GD.Employee_Goal_Setting IN (:Employee_Goal_Setting)
  AND GD.Goal_Status IN(:Completion_Status)
order by GD.Employee_Id,GD.Goal_Plan_Name
